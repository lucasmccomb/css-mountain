{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://cssmountain.dev/schemas/challenge.json",
  "title": "CSS Mountain Challenge",
  "description": "Schema for a CSS Mountain challenge definition",
  "type": "object",
  "required": [
    "id",
    "slug",
    "title",
    "description",
    "type",
    "difficulty",
    "zone",
    "isBoss",
    "html",
    "starterCss",
    "referenceSolutions",
    "validationRules",
    "hints",
    "maxScore",
    "metadata"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1,
      "description": "Unique challenge identifier"
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "description": "URL-safe slug"
    },
    "title": {
      "type": "string",
      "minLength": 3,
      "maxLength": 80,
      "description": "Display title for the challenge"
    },
    "description": {
      "type": "string",
      "minLength": 10,
      "description": "Brief description shown to the player"
    },
    "type": {
      "type": "string",
      "enum": ["match", "fix", "optimize", "build", "quiz"],
      "description": "Challenge type"
    },
    "difficulty": {
      "type": "string",
      "enum": ["junior", "mid-level", "senior", "staff", "principal"],
      "description": "Difficulty tier"
    },
    "zone": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5,
      "description": "Mountain zone number (1-5)"
    },
    "isBoss": {
      "type": "boolean",
      "description": "Whether this is a boss challenge for the zone"
    },
    "html": {
      "type": "string",
      "minLength": 1,
      "description": "HTML template the CSS applies to"
    },
    "starterCss": {
      "type": "string",
      "description": "Starting CSS code provided to the player"
    },
    "referenceSolutions": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 2,
      "description": "At least 2 reference solutions (hidden from player)"
    },
    "validationRules": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/ValidationRule"
      },
      "minItems": 1,
      "description": "Validation rules for grading"
    },
    "hints": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/HintTier"
      },
      "minItems": 3,
      "maxItems": 3,
      "description": "Three tiers of hints: nudge, clue, solution"
    },
    "maxScore": {
      "type": "integer",
      "const": 1000,
      "description": "Maximum score is always 1000"
    },
    "metadata": {
      "$ref": "#/definitions/ChallengeMetadata"
    }
  },
  "additionalProperties": false,
  "definitions": {
    "ValidationRule": {
      "type": "object",
      "required": ["type", "selector", "expected", "weight", "message"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["computed-style", "layout-bounds", "property-check"],
          "description": "Rule type identifier"
        },
        "selector": {
          "type": "string",
          "minLength": 1,
          "description": "CSS selector to target the element"
        },
        "property": {
          "type": "string",
          "description": "CSS property to validate"
        },
        "expected": {
          "oneOf": [
            { "type": "string" },
            { "type": "number" },
            {
              "type": "object",
              "required": ["min", "max"],
              "properties": {
                "min": { "type": "number" },
                "max": { "type": "number" }
              },
              "additionalProperties": false
            }
          ],
          "description": "Expected value: string, number, or { min, max } range"
        },
        "weight": {
          "type": "number",
          "minimum": 0,
          "description": "Points for this rule"
        },
        "message": {
          "type": "string",
          "description": "Feedback message on failure"
        }
      },
      "additionalProperties": false
    },
    "HintTier": {
      "type": "object",
      "required": ["level", "text"],
      "properties": {
        "level": {
          "type": "string",
          "enum": ["nudge", "clue", "solution"],
          "description": "Hint level"
        },
        "text": {
          "type": "string",
          "minLength": 1,
          "description": "Hint text"
        },
        "code": {
          "type": "string",
          "description": "Optional code snippet"
        }
      },
      "additionalProperties": false
    },
    "ChallengeMetadata": {
      "type": "object",
      "required": ["topics", "estimatedMinutes", "difficulty"],
      "properties": {
        "topics": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$"
          },
          "minItems": 1,
          "description": "CSS topics covered"
        },
        "estimatedMinutes": {
          "type": "number",
          "minimum": 1,
          "description": "Estimated time to complete in minutes"
        },
        "difficulty": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10,
          "description": "Granular difficulty within the zone (1-10)"
        }
      },
      "additionalProperties": false
    }
  }
}
